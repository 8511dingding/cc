<?xml version="1.0" encoding="utf-8"?>
<install version="1.5" type="plugin" group="system">
	<name>System - Auto Purge Cache</name>
	<license>http://www.gnu.org/copyleft/gpl.html GNU/GPL</license>
	<author>Mike Leeper</author>
	<authorEmail>web@mlwebtechnologies.com</authorEmail>
	<authorUrl>http://www.mlwebtechnologies.com</authorUrl>
	<creationDate>February 2010</creationDate>
	<copyright>(C) 2010 MLWebTechnologies</copyright>
	<version>1.2</version>
	<description>When activated, this plugin will automatically purge expired Joomla cache files.</description>
	<languages>
		<language tag="zh-CN">zh-CN.plg_system_auto_purge_cache.ini</language>
		<language tag="zh-TW">zh-TW.plg_system_auto_purge_cache.ini</language>
	</languages>
	<files>
		<filename plugin="auto_purge_cache">auto_purge_cache.php</filename>
	</files>
  <params>
    <param name="config_enable_purge" type="radio" default="0" label="Enable Automatic Purge">
			<option value="0">No</option>
			<option value="1">Yes</option>
		</param>
    <param name="config_previous" type="radio" default="86400" label="Purge Frequency">
			<option value="3600">Hourly</option>
			<option value="86400">Daily</option>
			<option value="604800">Weekly</option>
			<option value="2592000">Monthly</option>
		</param>
		<param name="config_freq_int" type="text" default="1" size="20" label="Purge Frequency Multiple" description="Frequency multiple.  (ie. 6 hours, 3 days, etc.)" />
    <param name="@spacer" type="spacer" default="" label="" description="" />
    <param name="config_enable_email" type="radio" default="0" label="Enable Email Alert">
			<option value="0">No</option>
			<option value="1">Yes</option>
		</param>
		<param name="config_email_list" type="textarea" cols="35" rows="5" default="" label="Email Alert To" description="Email Auto Purge Cache reports to these addresses (comma delimited)" />
		<param name="config_email_sender_name" type="text" default="Auto Purge Cache Plugin" size="60" label="Email Sender Name" description="Email Sender Name" />
		<param name="config_email_subject" type="text" default="Auto Purge Cache Report" size="60" label="Email Subject" description="Email Subject" />
		<param name="config_email_message" type="textarea" default="%header%Attention!%/header%The Joomla! Auto Purge Cache Plugin has removed %b%%count%%/b% expired files from the cache directory on the %b%%title%%/b% website.%br%%br%%br%This message was generated by the Auto Purge Cache Plugin." cols="35" rows="5" label="Email Message" description="Email Message" />
  </params>
</install>
