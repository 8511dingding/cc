<strong><font color=red>软件说明</font></strong>

	<br /><br />本插件的功能是在浏览器的标题栏上显示 Joomla! 1.5 网站的名称。
	]]></description>
	<files>
		<filename plugin="websitename">websitename.php</filename>
	</files>
	<languages>
		<language tag="en-GB">en-GB.plg_system_websitename.ini</language>
			<language tag="fr-FR">fr-FR.plg_system_websitename.ini</language>
			<language tag="zh-CN">zh-CN.plg_system_websitename.ini</language>
			<language tag="zh-TW">zh-TW.plg_system_websitename.ini</language>
	</languages>
	<params>
		<param name="@spacer" type="spacer" default="" label="" description="" />
    <param name="position" type="radio" default="0" label="position" description="Insert your website name before or after the page description (SEO improvement)">
			<option value="0">Before</option>
			<option value="1">After</option>
		</param>
    <param name="separator" type="text" default="-" size="10" label="separator" description="Char used to separate the name and the description"/>
	</params>
	<administration>
		<languages folder="admin">
			<language tag="en-GB">en-GB.plg_system_websitename.ini</language>
			<language tag="fr-FR">fr-FR.plg_system_websitename.ini</language>
			<language tag="zh-CN">zh-CN.plg_system_websitename.ini</language>
			<language tag="zh-TW">zh-TW.plg_system_websitename.ini</language>
		</languages>
	</administration>
</install>