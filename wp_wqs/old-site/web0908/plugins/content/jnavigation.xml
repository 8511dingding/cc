<?xml version="1.0" encoding="utf-8"?><install version="1.5.15" type="plugin" group="content">	<name>Content - JNavigation</name>	<author>Selim Alamo aka selimoff</author>	<creationDate>February 24, 2010</creationDate>	<license>http://www.gnu.org/copyleft/gpl.html GNU/GPL</license>	<authorEmail>selimovsky@yahoo.es</authorEmail>	<authorUrl></authorUrl>	<version>1.4.0</version>	<description>JNavigation Description</description>	<files>		<filename plugin="jnavigation">jnavigation.php</filename>		<folder>jnavigation</folder>		</files>	<languages folder="language">		<language tag="en-GB">en-GB.plg_content_jnavigation.ini</language>		<language tag="es-ES">es-ES.plg_content_jnavigation.ini</language>		<language tag="ru-RU">ru-RU.plg_content_jnavigation.ini</language>		<language tag="de-DE">de-DE.plg_content_jnavigation.ini</language>			</languages>		<params>		<param name="position" type="list" default="0" label="Position" description="Vertical alignment of JNavigation in relation to the text">			<option value="0">Above</option>					<option value="1">Below</option>			<option value="2">Outside content</option>					</param>		<param name="alignment" type="list" default="1" label="Alignment" description="Horizontal alignment of JNavigation in relation to the text">			<option value="0">Left</option>			<option value="1">Right</option>					<option value="2">Center</option>		</param>				<param name="navStyling" type="list" default="light" label="Navigation Styling" description="Select the navigation style for your template">			<option value="0">Light Classic</option>			<option value="1">Dark Classic</option>			<option value="2">Vimeo</option>			<option value="3">YouTube</option>			<option value="4">Panoramio</option>			<option value="5">Rocket</option>			<option value="6">Google</option>			<option value="7">Corbis</option>			<option value="8">Firefox</option>			<option value="9">Puma</option>		</param>	</params></install>